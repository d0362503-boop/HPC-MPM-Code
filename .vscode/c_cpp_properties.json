{
    "configurations": [
        {
            "name": "Linux-MPI-PETSc",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/module",
                "${workspaceFolder}/module/fluid",
                "${workspaceFolder}/module/fluid/FEM",
                "${workspaceFolder}/module/fluid/MPM",
                "${workspaceFolder}/module/solid",
                "${workspaceFolder}/module/solid/explicit",
                "${workspaceFolder}/module/solid/implicit",
                "${workspaceFolder}/module/solver",
                "${workspaceFolder}/work/src_fsi",
                "${workspaceFolder}/work/src_fluid",
                "${workspaceFolder}/work/src_solid",
                "${workspaceFolder}/external/petsc/include",
                "${workspaceFolder}/external/hdf5/include",
                "/usr/lib/x86_64-linux-gnu/openmpi/include",
                "/usr/lib/x86_64-linux-gnu/openmpi/include/openmpi"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "HAVE_HDF5"
            ],
            "compilerPath": "/usr/bin/mpicxx",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64",
            "compileCommands": "/home/pan/MPM-Code/build/compile_commands.json",
            "browse": {
                "path": [
                    "${workspaceFolder}/module",
                    "${workspaceFolder}/work/src_fsi",
                    "${workspaceFolder}/work/src_fluid",
                    "${workspaceFolder}/work/src_solid",
                    "${workspaceFolder}/external/petsc/include",
                    "${workspaceFolder}/external/hdf5/include"
                ],
                "limitSymbolsToIncludedHeaders": true,
                "databaseFilename": "${workspaceFolder}/.vscode/browse.db"
            }
        }
    ],
    "version": 4
}
